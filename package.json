{
	"name": "korea-stock-status",
	"displayName": "Korea Stock Status",
	"description": "한국주식 모니터링",
	"version": "1.0.0",
	"publisher": "1229juwon",
	"license": "MIT",
	"keywords": [
		"stock",
		"stock status",
		"korea stock",
		"kospi",
		"vscode"
	],
	"icon": "stocks.png",
	"engines": {
		"vscode": "^1.28.0",
		"node": "^18.0.0"
	},
	"categories": [
		"Other"
	],
	"scripts": {
		"vscode:prepublish": "npm run package",
		"compile": "webpack",
		"watch": "webpack --watch",
		"package": "webpack --mode production --devtool hidden-source-map",
		"publish": "vsce publish ",
		"package:local": "vsce package ",
		"compile-tests": "tsc -p . --outDir out",
		"watch-tests": "tsc -p . -w --outDir out",
		"pretest": "npm run compile-tests && npm run compile && npm run lint",
		"lint": "eslint src --ext ts",
		"test": "node ./out/test/runTest.js"
	},
	"activationEvents": [
		"*"
	],
	"main": "./dist/extension",
	"contributes": {
		"configuration": {
			"properties": {
				"stock-status.stocks": {
					"type": "array",
					"default": [
						"005930",
						{
							"code": "000660",
							"alias": "SK하이닉스",
							"hold_price": 0,
							"hold_num": 0
						}
					],
					"description": "한국 주식 코드(숫자만) 배열. 예: 005930, 000660"
				},
				"stock-status.updateInterval": {
					"type": "number",
					"default": 10000,
					"description": "데이터 업데이트 시간 간격, 단위: 밀리초"
				},
				"stock-status.riseColor": {
					"type": "string",
					"default": "",
					"description": "주식 상승 색상, 기본값은 시스템 따름"
				},
				"stock-status.fallColor": {
					"type": "string",
					"default": "",
					"description": "주식 하락 색상, 기본값은 시스템 따름"
				},
				"stock-status.showAccountPnL": {
					"type": "boolean",
					"default": true,
					"description": "보유 수익 정보 표시 여부"
				}
			}
		},
		"commands": [
			{
				"command": "stockStatus.start",
				"title": "Show Stock Status"
			},
			{
				"command": "stockStatus.stop",
				"title": "Hide Stock Status"
			},
			{
				"command": "stockStatus.add",
				"title": "Add Stock Status"
			}
		]
	},
	"devDependencies": {
		"@types/glob": "^7.2.0",
		"@types/mocha": "^9.1.1",
		"@types/node": "^16.18.126",
		"@types/vscode": "^1.28.0",
		"@typescript-eslint/eslint-plugin": "^5.27.0",
		"@typescript-eslint/parser": "^5.27.1",
		"@vscode/test-electron": "^2.1.3",
		"eslint": "^8.17.0",
		"eslint-config-prettier": "^8.5.0",
		"eslint-plugin-prettier": "^4.0.0",
		"glob": "^8.0.3",
		"mocha": "^10.0.0",
		"prettier": "^2.6.2",
		"ts-loader": "^9.3.0",
		"typescript": "^4.7.2",
		"webpack": "^5.76.0",
		"webpack-cli": "^4.10.0"
	},
	"dependencies": {
		"axios": "^0.27.2",
		"iconv-lite": "^0.7.2"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/1229juwon/stock-status"
	}
}
